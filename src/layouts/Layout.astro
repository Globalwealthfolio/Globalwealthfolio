---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
  noFooter?: boolean;
  noNav?: boolean;
  fullBleed?: boolean;
}

const {
  title = "Global Wealth Portfolio — Global Investment Portfolio Manager & Personal Finance Tracker | AI-Powered",
  description = "Global Wealth Portfolio is the leading global investment portfolio manager and personal finance tracker. Track your global investment portfolio, manage expenses, plan debt payoff, teach kids finance, and build wealth across 30+ currencies with AI-powered tools — all 100% local and private.",
  image = "/og-image.png",
  keywords = "global investment portfolio, investment portfolio manager, investment tracker, portfolio manager, expense tracker, investment portfolio management, wealth generation, wealth portfolio, global investment, crypto investment tracker, US investment tracker, investment dashboard, AI investment portfolio, AI investment tracker, kids finance, finance for kids, financial parenting, debt-payoff planner, budgeting tool, personal finance tracker, personal finance",
  noFooter = false,
  noNav = false,
  fullBleed = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4ecde" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href="https://globalwealthfolio.com" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://globalwealthfolio.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://globalwealthfolio.com${image}`} />
    <meta property="og:image:alt" content="Global Wealth Portfolio — Global Investment Portfolio Manager & Personal Finance Tracker" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Global Wealth Portfolio" />
    <meta property="og:image:type" content="image/png" />
    <meta property="article:tag" content="global investment portfolio" />
    <meta property="article:tag" content="investment portfolio manager" />
    <meta property="article:tag" content="personal finance tracker" />
    <meta property="article:tag" content="budgeting tool" />
    <meta property="article:tag" content="expense tracker" />
    <meta property="article:tag" content="financial parenting" />
    <meta property="article:tag" content="wealth generation" />
    <meta property="article:tag" content="crypto investment tracker" />
    <meta property="article:tag" content="AI investment tracker" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://globalwealthfolio.com" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`https://globalwealthfolio.com${image}`} />
    <meta property="twitter:image:alt" content="Global Wealth Portfolio — Global Investment Portfolio Manager & Personal Finance Tracker Dashboard" />
    <meta property="twitter:site" content="@globalwealthfolio" />
    <meta property="twitter:domain" content="globalwealthfolio.com" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GlobalWealth" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preconnect to Google Fonts for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Global Wealth Portfolio",
        "url": "https://globalwealthfolio.com",
        "description": "Free, private global investment portfolio manager and personal finance tracker. Track your global investment portfolio, expenses, crypto, US stocks, and build wealth with multi-currency support, OCR bank scanning, and AI-powered tools.",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "All",
        "browserRequirements": "Requires JavaScript",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "featureList": [
          "Global investment portfolio management",
          "Personal finance tracking",
          "Budgeting tool",
          "Debt-payoff planning",
          "Expense tracking",
          "Multi-currency support (30+ currencies)",
          "Bank statement OCR scanning",
          "AI-powered transaction categorization",
          "Goal and retirement planning",
          "Crypto investment tracking",
          "US investment tracking",
          "Net worth tracking",
          "Portfolio benchmarking",
          "Kids finance education"
        ]
      }
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J020W8NDX9"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J020W8NDX9');
    </script>

    <!-- Block FOUC: apply theme + class before paint -->
    <script is:inline>
      (function () {
        try {
          const k = "gwp:data:v1";
          const raw = localStorage.getItem(k);
          let theme = "system";
          if (raw) {
            const d = JSON.parse(raw);
            theme = d?.preferences?.theme ?? "system";
          }
          const sysDark =
            window.matchMedia &&
            window.matchMedia("(prefers-color-scheme: dark)").matches;
          const dark = theme === "dark" || (theme === "system" && sysDark);
          if (dark) document.documentElement.classList.add("dark");
          document.documentElement.dataset.theme = dark ? "dark" : "light";
          const lang = raw
            ? JSON.parse(raw)?.preferences?.language ?? "en"
            : (navigator.language || "en").split("-")[0];
          document.documentElement.lang = lang;
        } catch (_) {
          // noop
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-canvas-soft text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 btn-secondary"
    >
      Skip to content
    </a>
    {!noNav && <Nav />}
    <main id="main" class={fullBleed ? "" : ""}>
      <slot />
    </main>
    {!noFooter && <Footer />}

    <!-- App store: must run after DOM is ready -->
    <script>
      import "../scripts/app-store.ts";
    </script>
  </body>
</html>

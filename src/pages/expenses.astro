---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import DateRangeFilter from "../components/DateRangeFilter.astro";
---

<Layout title="Expenses — Global Wealth Portfolio">
  <section class="container-page page-section pt-3xl pb-2xl">
    <!-- First-run empty state banner -->
    <div id="exp-empty-banner" class="hidden card-elevated bg-gradient-finance border border-gold/30 p-lg mb-2xl">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-md">
        <div class="flex-1">
          <p class="text-caption-mono text-gold mb-xs">No transactions yet</p>
          <h2 class="text-display-sm mb-xs">Want to see how this page looks?</h2>
          <p class="text-body-sm text-body leading-relaxed">Load a sample set of expenses and income to explore the page with realistic data, or add your own transactions manually.</p>
        </div>
        <div class="flex gap-sm">
          <button id="seed-expenses" class="btn-primary" type="button">Load sample data</button>
        </div>
      </div>
    </div>

    <PageHeader
      title="Expenses"
      description="Daily, monthly, and recurring expenses in one place. See where your money goes and track your savings rate."
      primaryAction={{ label: "+ Add expense", id: "add-expense" }}
      secondaryAction={{ label: "Import", href: "/import" }}
      filters={[
        {
          id: "type",
          label: "Type",
          options: [
            { value: "all", label: "All" },
            { value: "expense", label: "Expenses" },
            { value: "income", label: "Income" },
          ],
        },
        {
          id: "category",
          label: "Category",
          options: [
            { value: "all", label: "All Categories" },
            { value: "Housing", label: "Housing" },
            { value: "Food & Dining", label: "Food & Dining" },
            { value: "Transport", label: "Transport" },
            { value: "Utilities", label: "Utilities" },
            { value: "Healthcare", label: "Healthcare" },
            { value: "Education", label: "Education" },
            { value: "Shopping", label: "Shopping" },
            { value: "Entertainment", label: "Entertainment" },
            { value: "Insurance", label: "Insurance" },
            { value: "Investment", label: "Investment" },
            { value: "Travel", label: "Travel" },
            { value: "Personal Care", label: "Personal Care" },
            { value: "Gifts", label: "Gifts" },
            { value: "Salary", label: "Salary" },
            { value: "Freelance", label: "Freelance" },
            { value: "Dividend", label: "Dividend" },
            { value: "Interest", label: "Interest" },
            { value: "Rental Income", label: "Rental Income" },
            { value: "Bonus", label: "Bonus" },
            { value: "Refund", label: "Refund" },
            { value: "Other Income", label: "Other Income" },
            { value: "Other", label: "Other" },
          ],
        },
        {
          id: "recurring",
          label: "Recurring",
          options: [
            { value: "all", label: "All" },
            { value: "one-time", label: "One-time" },
            { value: "monthly", label: "Monthly" },
            { value: "quarterly", label: "Quarterly" },
            { value: "yearly", label: "Yearly" },
          ],
        },
      ]}
    />

    <div class="mb-2xl -mt-lg">
      <DateRangeFilter id="exp-range" defaultPreset="all" showLabel={true} />
    </div>

    <!-- Summary -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-2xl">
      <div class="card">
        <p class="text-caption-mono text-body mb-xs" data-stat-label="thismonth">This month · Spent</p>
        <p class="text-display-sm" data-stat="thismonth">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs" data-stat-label="income-month">This month · Income</p>
        <p class="text-display-sm text-gain" data-stat="income-month">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Avg / month</p>
        <p class="text-display-sm" data-stat="avg">₹0</p>
        <p class="text-caption text-mute mt-xs">Last 3 months</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Savings rate</p>
        <p class="text-display-sm" data-stat="savings">—</p>
        <p class="text-caption text-mute mt-xs">Income vs expenses</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-md mb-2xl">
      <div class="card">
        <h2 class="text-display-sm mb-md">Spending by category</h2>
          <div class="h-48 max-sm:chart-sm">
            <canvas id="categoryChart"></canvas>
          </div>
      </div>
      <div class="card">
        <h2 class="text-display-sm mb-md">Monthly trend</h2>
          <div class="h-48 max-sm:chart-sm">
            <canvas id="trendChart"></canvas>
          </div>
      </div>
    </div>

    <!-- Table -->
      <div class="card p-0 overflow-hidden">
        <div class="overflow-x-auto scroll-thin">
          <table class="w-full text-body-sm" data-table="expenses">
            <thead>
              <tr class="text-left text-caption-mono text-body bg-canvas-soft-2">
                <th class="font-medium py-sm px-md hide-mobile">#</th>
                <th class="font-medium py-sm px-md">Type</th>
                <th class="font-medium py-sm px-md">Description</th>
                <th class="font-medium py-sm px-md hide-tablet">Category</th>
                <th class="font-medium py-sm px-md hide-tablet">Date</th>
                <th class="font-medium py-sm px-md text-right">Amount</th>
                <th class="font-medium py-sm px-md hide-mobile">Recurring</th>
                <th class="font-medium py-sm px-md hide-mobile">Notes</th>
                <th class="font-medium py-sm px-md text-right">Actions</th>
              </tr>
            </thead>
            <tbody id="expenses-tbody">
              <tr>
                <td colspan="9" class="text-center py-5xl">Loading…</td>
              </tr>
            </tbody>
          </table>
        </div>
    </div>
  </section>

  <!-- Add / Edit expense modal -->
  <dialog id="expense-modal" class="rounded-lg p-0 max-w-lg w-full shadow-level-5 backdrop:bg-black/30">
    <form id="expense-form" method="dialog" class="p-lg">
      <div class="flex items-center justify-between mb-md">
        <h2 class="text-display-sm" id="exp-modal-title">Add Expense</h2>
        <button type="button" data-close-modal class="btn-icon" aria-label="Close">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <input type="hidden" id="exp-id" name="id" />
      <div class="space-y-md">
        <div>
          <label class="label">Transaction type *</label>
          <div class="grid grid-cols-2 gap-sm">
            <label class="flex items-center gap-sm cursor-pointer card-soft p-sm">
              <input type="radio" name="type" value="expense" class="exp-type-radio accent-current" checked />
              <div>
                <p class="text-body-sm-strong">Expense</p>
                <p class="text-caption text-mute">Money going out</p>
              </div>
            </label>
            <label class="flex items-center gap-sm cursor-pointer card-soft p-sm">
              <input type="radio" name="type" value="income" class="exp-type-radio accent-current" />
              <div>
                <p class="text-body-sm-strong">Income</p>
                <p class="text-caption text-mute">Money coming in</p>
              </div>
            </label>
          </div>
        </div>
        <div>
          <label class="label" for="exp-desc">Description *</label>
          <input class="input" type="text" id="exp-desc" name="description" required />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
          <div>
            <label class="label" for="exp-category">Category *</label>
            <select class="select" id="exp-category" name="category" required>
              <option value="Housing">Housing</option>
              <option value="Food & Dining">Food & Dining</option>
              <option value="Transport">Transport</option>
              <option value="Utilities">Utilities</option>
              <option value="Healthcare">Healthcare</option>
              <option value="Education">Education</option>
              <option value="Shopping">Shopping</option>
              <option value="Entertainment">Entertainment</option>
              <option value="Insurance">Insurance</option>
              <option value="Investment">Investment</option>
              <option value="Travel">Travel</option>
              <option value="Personal Care">Personal Care</option>
              <option value="Gifts">Gifts</option>
              <option value="Salary">Salary</option>
              <option value="Freelance">Freelance</option>
              <option value="Dividend">Dividend</option>
              <option value="Interest">Interest</option>
              <option value="Rental Income">Rental Income</option>
              <option value="Bonus">Bonus</option>
              <option value="Refund">Refund</option>
              <option value="Other Income">Other Income</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label class="label" for="exp-date">Date *</label>
            <input class="input" type="date" id="exp-date" name="date" required />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
          <div>
            <label class="label" for="exp-amount">Amount *</label>
            <input class="input" type="number" id="exp-amount" name="amount" min="0" step="any" required />
          </div>
          <div>
            <label class="label" for="exp-recurring">Recurring</label>
            <select class="select" id="exp-recurring" name="recurring">
              <option value="one-time">One-time</option>
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
          <div>
            <label class="label" for="exp-from">From</label>
            <input class="input" type="date" id="exp-from" name="recurringFrom" />
          </div>
          <div>
            <label class="label" for="exp-to">To</label>
            <input class="input" type="date" id="exp-to" name="recurringTo" />
          </div>
        </div>
        <div>
          <label class="label" for="exp-notes">Notes</label>
          <input class="input" type="text" id="exp-notes" name="notes" />
        </div>
      </div>
      <div class="flex justify-end gap-sm mt-lg">
        <button type="button" data-close-modal class="btn-secondary">Cancel</button>
        <button type="submit" class="btn-primary">Save expense</button>
      </div>
    </form>
  </dialog>
</Layout>

<script>
  import "../scripts/expenses.ts";
  import { initDateRangeFilter } from "../scripts/date-range-filter";
  import { hasAnyData, seedSampleData } from "../lib/sample-data";

  try { initDateRangeFilter(); } catch (_) {}

  // Show empty-state banner when there is no data
  const banner = document.getElementById("exp-empty-banner");
  if (banner && !hasAnyData()) {
    banner.classList.remove("hidden");
  }
  document.getElementById("seed-expenses")?.addEventListener("click", () => {
    if (confirm("Load sample data? This will replace anything you've already entered.")) {
      seedSampleData();
      banner?.classList.add("hidden");
    }
  });
</script>

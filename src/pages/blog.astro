---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Blog — Global Wealth Portfolio | Investment, Expense, and Goal Tracking Guides"
  description="Read expert guides on portfolio management, expense tracking, goal planning, and achieving financial freedom. Practical advice for global investors."
>
  <section class="container-page page-section pt-3xl pb-2xl">
    <p class="text-caption-mono text-gold mb-xs">Blog</p>
    <h1 class="text-display-lg mb-md">Guides &amp; articles for smarter financial tracking.</h1>
    <p class="text-body-lg text-body max-w-2xl mb-4xl leading-relaxed">
      Practical advice on portfolio management, expense tracking, goal planning,
      and building lasting financial freedom — written for global investors.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
      <article class="card hover:shadow-level-3 transition-shadow flex flex-col gap-sm">
        <span class="badge badge-gain w-fit">Featured</span>
        <h3 class="text-display-sm text-ink">How to Use This Portfolio Manager</h3>
        <p class="text-body-md text-body leading-relaxed">A complete walkthrough — from importing your first investment to tracking expenses, setting goals, and monitoring benchmarks.</p>
        <div class="flex items-center justify-between mt-auto pt-sm border-t border-hairline">
          <span class="text-caption text-mute">Jun 9, 2026 · 6 min read</span>
          <a href="/blog/how-to-use-this-portfolio-manager" class="text-body-sm text-link hover:underline">Read more →</a>
        </div>
      </article>
      <article class="card hover:shadow-level-3 transition-shadow flex flex-col gap-sm">
        <span class="badge badge-gain w-fit">Featured</span>
        <h3 class="text-display-sm text-ink">Tracking Expenses Along With Investments</h3>
        <p class="text-body-md text-body leading-relaxed">Why tracking both sides of your financial life gives you a complete picture and keeps your financial future safe.</p>
        <div class="flex items-center justify-between mt-auto pt-sm border-t border-hairline">
          <span class="text-caption text-mute">Jun 9, 2026 · 5 min read</span>
          <a href="/blog/track-expenses-with-investments" class="text-body-sm text-link hover:underline">Read more →</a>
        </div>
      </article>
      <article class="card hover:shadow-level-3 transition-shadow flex flex-col gap-sm">
        <span class="badge badge-gain w-fit">Featured</span>
        <h3 class="text-display-sm text-ink">Step-by-Step Goals for Financial Freedom</h3>
        <p class="text-body-md text-body leading-relaxed">How breaking your financial goals into actionable steps with tracking and projections leads to lasting financial freedom.</p>
        <div class="flex items-center justify-between mt-auto pt-sm border-t border-hairline">
          <span class="text-caption text-mute">Jun 9, 2026 · 6 min read</span>
          <a href="/blog/step-by-step-goals-financial-freedom" class="text-body-sm text-link hover:underline">Read more →</a>
        </div>
      </article>
      <article class="card hover:shadow-level-3 transition-shadow flex flex-col gap-sm">
        <span class="badge badge-gain w-fit">Featured</span>
        <h3 class="text-display-sm text-ink">Financial Freedom Is Not a Luxury</h3>
        <p class="text-body-md text-body leading-relaxed">Financial freedom is the foundation for a life lived on your own terms — and it is more accessible than you think.</p>
        <div class="flex items-center justify-between mt-auto pt-sm border-t border-hairline">
          <span class="text-caption text-mute">Jun 9, 2026 · 5 min read</span>
          <a href="/blog/financial-freedom-necessity" class="text-body-sm text-link hover:underline">Read more →</a>
        </div>
      </article>
    </div>

    <hr class="border-hairline my-4xl" />

    <!-- Admin blog posts -->
    <div class="mb-md">
      <p class="text-caption-mono text-gold mb-xs">Latest from the author</p>
      <h2 class="text-display-md">Thoughts on investing &amp; finance.</h2>
    </div>

    <div id="admin-blog-list" class="grid grid-cols-1 md:grid-cols-2 gap-md mb-2xl">
      <div class="md:col-span-2 text-center py-5xl card-soft">
        <p class="text-body-md text-body">Loading…</p>
      </div>
    </div>

    <hr class="border-hairline my-4xl" />

    <!-- About Me -->
    <div class="mb-4xl">
      <p class="text-caption-mono text-gold mb-xs">About Me</p>
      <h2 class="text-display-md mb-lg">Hello, I&rsquo;m Sourabhsingh Rajput</h2>
      <div class="text-body-md text-body leading-relaxed space-y-md max-w-3xl">
        <p>
          A mechanical engineering professional with over a decade of experience
          in core product design. My career has been built on solving complex
          engineering challenges, creating innovative solutions, and contributing
          to product development across industries.
        </p>
        <p>
          Alongside my engineering journey, I&rsquo;ve nurtured a strong passion
          for the financial markets. For more than 11 years, I&rsquo;ve actively
          traded, studied, and refined investment strategies &mdash; turning what
          began as a hobby into a parallel expertise. Over time, I started
          managing investment portfolios for 8 clients, building customized
          strategies and dashboards to track performance, risk, and goals.
        </p>
        <p>
          Initially, this meant countless hours of maintaining Excel spreadsheets
          and financial dashboards. But now, with this website, I&rsquo;ve
          streamlined the process &mdash; reducing manual work and creating a
          more efficient, transparent, and scalable way to manage portfolios.
        </p>
        <p>
          This platform reflects both sides of my professional life:
        </p>
        <ul class="list-disc pl-lg space-y-xs">
          <li>The precision and problem-solving mindset of an engineer.</li>
          <li>The analytical and strategic thinking of a financial market practitioner.</li>
        </ul>
        <p>
          My goal is simple: to make portfolio management smarter, easier, and
          more accessible &mdash; for myself, my clients, and anyone passionate
          about building wealth with clarity.
        </p>
        <p class="text-body-md text-ink font-medium pt-sm">
          Happy to connect with like‑minded people who share an interest in
          engineering, investing, or building smarter financial tools.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { loadData, subscribe } from "../lib/store";

  function esc(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function formatDate(iso) {
    try {
      return new Date(iso).toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
    } catch { return iso; }
  }

  function render() {
    const list = document.getElementById("admin-blog-list");
    if (!list) return;
    const posts = loadData().blog
      .filter((p) => p.status === "published")
      .sort((a, b) => ((a.publishedAt ?? a.updatedAt) < (b.publishedAt ?? b.updatedAt) ? 1 : -1));

    if (posts.length === 0) {
      list.innerHTML = `<div class="md:col-span-2 text-center py-5xl card-soft"><p class="text-body-sm text-body">No posts yet. Check back soon!</p></div>`;
      return;
    }

    list.innerHTML = posts
      .map(
        (p) => `
      <article class="card hover:shadow-level-3 transition-shadow flex flex-col gap-sm">
        <div class="flex items-center justify-between">
          <span class="text-caption text-mute">${formatDate(p.publishedAt ?? p.updatedAt)}</span>
        </div>
        <h3 class="text-display-sm text-ink">${esc(p.title)}</h3>
        ${
          p.excerpt
            ? `<p class="text-body-md text-body line-clamp-2">${esc(p.excerpt)}</p>`
            : `<p class="text-body-md text-body line-clamp-2">${esc(p.content.slice(0, 140))}${p.content.length > 140 ? "…" : ""}</p>`
        }
        ${
          p.tags.length > 0
            ? `<div class="flex flex-wrap gap-xs mt-xs">${p.tags.map((t) => `<span class="badge">${esc(t)}</span>`).join("")}</div>`
            : ""
        }
        <div class="flex items-center justify-between mt-md pt-sm border-t border-hairline">
          <span class="text-caption text-mute">${p.authorName ? `By ${esc(p.authorName)}` : ""}</span>
          <span class="text-caption text-mute">${p.content.split(/\s+/).filter(Boolean).length} words</span>
        </div>
      </article>`,
      )
      .join("");
  }

  subscribe(render);
  render();
</script>

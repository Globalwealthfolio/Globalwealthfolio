---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import DateRangeFilter from "../components/DateRangeFilter.astro";
---

<Layout title="EMI Tracker — Global Wealth Portfolio">
  <section class="container-page page-section pt-3xl pb-2xl">
    <PageHeader
      title="EMI Tracker"
      description="Track home, car, personal, and education loans side by side. Watch principal shrink over time."
      primaryAction={{ label: "+ Add EMI", id: "add-emi" }}
      filters={[
        {
          id: "type",
          label: "Type",
          options: [
            { value: "all", label: "All Types" },
            { value: "Home Loan", label: "Home Loan" },
            { value: "Car Loan", label: "Car Loan" },
            { value: "Personal Loan", label: "Personal Loan" },
            { value: "Education Loan", label: "Education Loan" },
            { value: "Gold Loan", label: "Gold Loan" },
            { value: "Two-Wheeler Loan", label: "Two-Wheeler Loan" },
            { value: "Business Loan", label: "Business Loan" },
            { value: "Other", label: "Other" },
          ],
        },
      ]}
    />

    <div class="mb-2xl -mt-lg max-sm:mt-0">
      <DateRangeFilter id="emi-range" defaultPreset="all" showLabel={true} />
    </div>

    <div class="card-soft mb-2xl p-md flex items-center justify-between gap-md flex-wrap">
      <p class="text-body-sm text-body">
        Need to compare loan options or plan prepayment strategies?
      </p>
      <a href="/calculators?calc=emi" class="btn-primary shrink-0" style="height:36px;font-size:13px;">Open Advance EMI Calculator</a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-2xl">
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Monthly EMI</p>
        <p class="text-display-sm" data-stat="monthly">₹0</p>
        <p class="text-caption text-mute mt-xs"><span data-stat="active">0</span> active loans</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Total Outstanding</p>
        <p class="text-display-sm" data-stat="outstanding">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Total Interest Paid</p>
        <p class="text-display-sm" data-stat="interest">₹0</p>
        <p class="text-caption text-mute mt-xs">Estimated so far</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Closing Soon</p>
        <p class="text-display-sm" data-stat="closing">0</p>
        <p class="text-caption text-mute mt-xs">Within 6 months</p>
      </div>
    </div>

      <div class="card p-0 overflow-hidden">
        <div class="overflow-x-auto scroll-thin">
          <table class="w-full text-body-sm" data-table="emi">
            <thead>
              <tr class="text-left text-caption-mono text-body bg-canvas-soft-2">
                <th class="font-medium py-sm px-md hide-mobile">#</th>
                <th class="font-medium py-sm px-md">Loan</th>
                <th class="font-medium py-sm px-md hide-mobile">Type</th>
                <th class="font-medium py-sm px-md text-right hide-tablet">Principal</th>
                <th class="font-medium py-sm px-md text-right">EMI</th>
                <th class="font-medium py-sm px-md text-right hide-mobile">Rate</th>
                <th class="font-medium py-sm px-md text-right hide-mobile">Tenure</th>
                <th class="font-medium py-sm px-md hide-mobile">Start</th>
                <th class="font-medium py-sm px-md text-right">Outstanding</th>
                <th class="font-medium py-sm px-md w-32 max-sm:w-20">Progress</th>
                <th class="font-medium py-sm px-md text-right">Actions</th>
              </tr>
            </thead>
            <tbody id="emi-tbody">
              <tr><td colspan="11" class="text-center py-5xl text-body">Loading…</td></tr>
            </tbody>
          </table>
        </div>
    </div>
  </section>

  <dialog id="emi-modal" class="rounded-lg p-0 max-w-lg w-full shadow-level-5 backdrop:bg-black/30">
    <form id="emi-form" method="dialog" class="p-lg">
      <div class="flex items-center justify-between mb-md">
        <h2 class="text-display-sm" id="emi-modal-title">Add EMI / Loan</h2>
        <button type="button" data-close-modal class="btn-icon" aria-label="Close">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <input type="hidden" id="emi-id" name="id" />
      <div class="space-y-md">
        <div>
          <label class="label" for="emi-name">Loan Name *</label>
          <input class="input" type="text" id="emi-name" name="name" required />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
          <div>
            <label class="label" for="emi-type">Type *</label>
            <select class="select" id="emi-type" name="type" required>
              <option value="Home Loan">Home Loan</option>
              <option value="Car Loan">Car Loan</option>
              <option value="Personal Loan">Personal Loan</option>
              <option value="Education Loan">Education Loan</option>
              <option value="Gold Loan">Gold Loan</option>
              <option value="Two-Wheeler Loan">Two-Wheeler Loan</option>
              <option value="Business Loan">Business Loan</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label class="label" for="emi-start">Start Date *</label>
            <input class="input" type="date" id="emi-start" name="startDate" required />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
          <div>
            <label class="label" for="emi-principal">Principal *</label>
            <input class="input" type="number" id="emi-principal" name="principal" min="0" step="any" required />
          </div>
          <div>
            <label class="label" for="emi-emi">Monthly EMI *</label>
            <input class="input" type="number" id="emi-emi" name="emi" min="0" step="any" required />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-sm">
          <div>
            <label class="label" for="emi-rate">Interest Rate (% p.a.) *</label>
            <input class="input" type="number" id="emi-rate" name="rate" min="0" step="any" required />
          </div>
          <div>
            <label class="label" for="emi-tenure">Tenure (months) *</label>
            <input class="input" type="number" id="emi-tenure" name="tenure" min="1" required />
          </div>
        </div>
        <div>
          <label class="label" for="emi-outstanding">Outstanding</label>
          <input class="input" type="number" id="emi-outstanding" name="outstanding" min="0" step="any" />
        </div>
        <div>
          <label class="label" for="emi-notes">Notes</label>
          <input class="input" type="text" id="emi-notes" name="notes" />
        </div>
        <div class="card-soft text-caption text-body">
          <p>Calculated EMI: <strong data-calc-emi>—</strong> · Total interest: <strong data-calc-interest>—</strong></p>
        </div>
      </div>
      <div class="flex justify-end gap-sm mt-lg">
        <button type="button" data-close-modal class="btn-secondary">Cancel</button>
        <button type="submit" class="btn-primary">Save loan</button>
      </div>
    </form>
  </dialog>

  <!-- Debt Payoff Planner Section -->
  <section class="container-page page-section pt-2xl pb-2xl" id="debt-payoff-section" aria-label="Debt Payoff Planner" style="display:none">

    <div class="max-w-3xl text-left mb-2xl">
      <h2 class="text-display-lg text-ink mb-md">Debt Payoff Planner</h2>
      <p class="text-body-lg text-body">Compare <strong>Debt Avalanche</strong> (highest interest first) vs <strong>Debt Snowball</strong> (smallest balance first). See how extra payments accelerate your debt freedom.</p>
    </div>

    <!-- Strategy & Extra Payment -->
    <div class="card mb-2xl">
      <div class="flex flex-wrap items-end gap-lg">
        <fieldset>
          <legend class="label">Payoff Strategy</legend>
          <div class="flex gap-md mt-xs" role="radiogroup" aria-label="Payoff strategy">
            <label class="flex items-center gap-xs cursor-pointer">
              <input type="radio" name="strategy" value="avalanche" checked aria-describedby="strategy-avalanche-desc" />
              <span>Avalanche <span id="strategy-avalanche-desc" class="text-body text-caption">(highest interest first)</span></span>
            </label>
            <label class="flex items-center gap-xs cursor-pointer">
              <input type="radio" name="strategy" value="snowball" />
              <span>Snowball <span class="text-body text-caption">(smallest balance first)</span></span>
            </label>
          </div>
        </fieldset>
        <div>
          <label class="label" for="extra-payment">Extra Monthly Payment</label>
          <div class="flex items-center gap-xs">
            <span class="text-body text-body-sm" aria-hidden="true">₹</span>
            <input class="input w-36" type="number" id="extra-payment" min="0" value="5000" step="500" aria-label="Extra monthly payment amount" />
          </div>
        </div>
      </div>
    </div>

    <!-- Warning Area -->
    <div id="payoff-warning" class="hidden"></div>

    <!-- Comparison Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-md mb-2xl" id="payoff-comparison" aria-label="Strategy comparison">
      <div class="card text-center py-2xl col-span-full">
        <p class="text-body text-body">Loading debt payoff projections…</p>
      </div>
    </div>

    <!-- Payoff Order -->
    <div class="card mb-2xl" id="payoff-order" aria-label="Payoff order per strategy"></div>

    <!-- Overall Progress -->
    <div class="card mb-2xl" id="payoff-progress">
      <div class="flex items-center justify-between mb-sm">
        <span class="text-caption-mono text-body">Overall Progress</span>
        <span class="text-caption-mono text-body" id="progress-pct" aria-live="polite">0%</span>
      </div>
      <div class="h-2.5 bg-canvas-soft-2 rounded-full overflow-hidden" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progress-aria">
        <div class="h-full bg-gradient-gain rounded-full transition-all duration-700 ease-out" id="progress-bar" style="width: 0%"></div>
      </div>
    </div>

    <!-- Charts -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-md mb-2xl">
      <div class="card">
        <h3 class="text-display-sm mb-md">Balance Reduction Timeline</h3>
        <div class="chart-container" style="position: relative; height: 280px;">
          <canvas id="balance-chart" aria-label="Balance reduction timeline chart"></canvas>
        </div>
      </div>
      <div class="card">
        <h3 class="text-display-sm mb-md">Debt Distribution</h3>
        <div class="chart-container" style="position: relative; height: 280px;">
          <canvas id="debt-pie-chart" aria-label="Debt distribution pie chart"></canvas>
        </div>
      </div>
    </div>

    <!-- Export / Reset -->
    <div class="card">
      <div class="flex flex-wrap gap-sm">
        <button class="btn-secondary" id="export-csv" type="button" aria-label="Export payoff plan as CSV">Export CSV</button>
        <button class="btn-secondary" id="export-pdf" type="button" aria-label="Print payoff plan as PDF">Print as PDF</button>
      </div>
    </div>

  </section>
</Layout>

<script>
  import "../scripts/emi.ts";
  import { initDateRangeFilter } from "../scripts/date-range-filter";
  import { initDebtPayoff } from "../scripts/debt-payoff";
  initDateRangeFilter();
  initDebtPayoff();
</script>

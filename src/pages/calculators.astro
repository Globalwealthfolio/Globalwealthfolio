  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll("[data-tax-regime]").forEach(function(el) {
        el.addEventListener("change", function() {
          const val = parseInt(this.value);
          document.getElementById("tax-regime").value = String(val);
          const oldDeductions = document.getElementById("tax-old-deductions");
          if (oldDeductions) {
            oldDeductions.classList.toggle("hidden", val >= 80);
          }
          const event = new Event("input", { bubbles: true });
          document.getElementById("tax-regime").dispatchEvent(event);
        });
      });
    });
  </script>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll("[data-quick]").forEach(function(btn) {
        btn.addEventListener("click", function() {
          var target = this.dataset.target;
          var value = this.dataset.value;
          var input = document.getElementById(target);
          if (input) {
            input.value = value;
            input.dispatchEvent(new Event("input", { bubbles: true }));
          }
        });
      });
    });
  </script>


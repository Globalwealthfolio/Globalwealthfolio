---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Layout title="Investments — Global Wealth Portfolio">
  <section class="container-page pt-3xl pb-2xl">
    <PageHeader
      title="Investments"
      description="All your assets, returns, and allocations in one place. Filter by type, goal, or risk profile."
      primaryAction={{ label: "+ Add investment", id: "add-investment" }}
      secondaryAction={{ label: "Import", href: "/import" }}
      filters={[
        {
          id: "type",
          label: "Type",
          options: [
            { value: "all", label: "All Types" },
            { value: "Equity", label: "Equity" },
            { value: "Debt", label: "Debt" },
            { value: "Gold", label: "Gold" },
            { value: "Real Estate", label: "Real Estate" },
            { value: "Crypto", label: "Crypto" },
            { value: "International", label: "International" },
            { value: "ETF", label: "ETF" },
            { value: "Cash", label: "Cash" },
            { value: "PPF", label: "PPF" },
            { value: "EPF", label: "EPF" },
            { value: "Fixed Deposit", label: "Fixed Deposit" },
            { value: "Bonds", label: "Bonds" },
          ],
        },
        {
          id: "goal",
          label: "Goal",
          options: [{ value: "all", label: "All Goals" }],
        },
        {
          id: "risk",
          label: "Risk",
          options: [
            { value: "all", label: "All Risk" },
            { value: "low", label: "Low (1-3)" },
            { value: "medium", label: "Medium (4-6)" },
            { value: "high", label: "High (7-10)" },
          ],
        },
      ]}
    />

    <!-- Summary row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-2xl">
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Invested</p>
        <p class="text-display-sm" data-stat="invested">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Current</p>
        <p class="text-display-sm" data-stat="current">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Total Gain</p>
        <p class="text-display-sm" data-stat="gain">₹0</p>
      </div>
      <div class="card">
        <p class="text-caption-mono text-body mb-xs">Return</p>
        <p class="text-display-sm" data-stat="return">0.00%</p>
      </div>
    </div>

    <!-- Table -->
    <div class="card p-0 overflow-hidden">
      <div class="overflow-x-auto scroll-thin">
        <table class="w-full text-body-sm">
          <thead>
            <tr class="text-left text-caption-mono text-body bg-canvas-soft-2">
              <th class="font-medium py-sm px-md">#</th>
              <th class="font-medium py-sm px-md">Asset</th>
              <th class="font-medium py-sm px-md">Type</th>
              <th class="font-medium py-sm px-md">Goal</th>
              <th class="font-medium py-sm px-md">Date</th>
              <th class="font-medium py-sm px-md text-right">Invested</th>
              <th class="font-medium py-sm px-md text-right">Current</th>
              <th class="font-medium py-sm px-md text-right">Gain</th>
              <th class="font-medium py-sm px-md">Risk</th>
              <th class="font-medium py-sm px-md">Time to Goal</th>
              <th class="font-medium py-sm px-md">Notes</th>
              <th class="font-medium py-sm px-md text-right">Actions</th>
            </tr>
          </thead>
          <tbody id="investments-tbody">
            <tr>
              <td colspan="12" class="text-center py-5xl">
                <p class="text-body-md text-body">Loading…</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Add / Edit investment modal -->
  <dialog id="investment-modal" class="rounded-lg p-0 max-w-lg w-full shadow-level-5 backdrop:bg-black/30">
    <form id="investment-form" method="dialog" class="p-lg">
      <div class="flex items-center justify-between mb-md">
        <h2 class="text-display-sm" id="inv-modal-title">Add Investment</h2>
        <button type="button" data-close-modal class="btn-icon" aria-label="Close">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <input type="hidden" id="inv-id" name="id" />
      <div class="space-y-md">
        <div>
          <label class="label" for="inv-name">Asset Name *</label>
          <input class="input" type="text" id="inv-name" name="name" required placeholder="e.g. Reliance Industries" />
        </div>
        <div class="grid grid-cols-2 gap-sm">
          <div>
            <label class="label" for="inv-type">Type *</label>
            <select class="select" id="inv-type" name="type" required>
              <option value="Equity">Equity</option>
              <option value="Debt">Debt</option>
              <option value="Gold">Gold</option>
              <option value="Real Estate">Real Estate</option>
              <option value="Crypto">Crypto</option>
              <option value="International">International</option>
              <option value="ETF">ETF</option>
              <option value="Cash">Cash</option>
              <option value="PPF">PPF</option>
              <option value="EPF">EPF</option>
              <option value="Fixed Deposit">Fixed Deposit</option>
              <option value="Bonds">Bonds</option>
            </select>
          </div>
          <div>
            <label class="label" for="inv-date">Date *</label>
            <input class="input" type="date" id="inv-date" name="date" required />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-sm">
          <div>
            <label class="label" for="inv-amount">Invested *</label>
            <input class="input" type="number" id="inv-amount" name="amount" min="0" step="any" required />
          </div>
          <div>
            <label class="label" for="inv-current">Current Value</label>
            <input class="input" type="number" id="inv-current" name="currentValue" min="0" step="any" />
          </div>
        </div>
        <div>
          <label class="label" for="inv-goal">Goal Mapping</label>
          <select class="select" id="inv-goal" name="goalId">
            <option value="">— None —</option>
          </select>
        </div>
        <div>
          <label class="label" for="inv-risk">Risk Score: <span id="inv-risk-val">5</span></label>
          <input class="w-full" type="range" id="inv-risk" name="risk" min="1" max="10" value="5" />
        </div>
        <div>
          <label class="label" for="inv-notes">Notes / Tags</label>
          <input class="input" type="text" id="inv-notes" name="notes" placeholder="Optional" />
        </div>
      </div>
      <div class="flex justify-end gap-sm mt-lg">
        <button type="button" data-close-modal class="btn-secondary">Cancel</button>
        <button type="submit" class="btn-primary">Save investment</button>
      </div>
    </form>
  </dialog>
</Layout>

<script>
  import "../scripts/investments.ts";
</script>

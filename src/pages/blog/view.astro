---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Blog Post — Global Wealth Portfolio"
  description="Read the full blog post"
>
  <article class="container-page page-section pt-3xl pb-2xl max-w-3xl">
    <a href="/blog" class="inline-flex items-center gap-xs text-body-sm text-link hover:underline mb-md">&larr; Back to blog</a>
    <div id="post-content">
      <p class="text-body-md text-body">Loading…</p>
    </div>
  </article>
</Layout>

<style>
  .prose-custom h1,
  .prose-custom h2,
  .prose-custom h3 {
    color: var(--color-ink);
    font-weight: 600;
    line-height: 1.3;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }
  .prose-custom h1 { font-size: 1.75rem; }
  .prose-custom h2 { font-size: 1.375rem; }
  .prose-custom h3 { font-size: 1.125rem; }
  .prose-custom blockquote {
    border-left: 3px solid var(--color-gold);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-body);
    font-style: italic;
  }
  .prose-custom ul,
  .prose-custom ol {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }
  .prose-custom li {
    margin-bottom: 0.25rem;
  }
  .prose-custom a {
    color: var(--color-link);
    text-decoration: underline;
  }
  .prose-custom a:hover {
    color: var(--color-link-deep);
  }
  .prose-custom strong { font-weight: 600; }
  .prose-custom em { font-style: italic; }
  .prose-custom u { text-decoration: underline; }
  .prose-custom p {
    margin-bottom: 0.5rem;
  }
  .prose-custom span[style] {
    display: inline;
  }
  .prose-custom table {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
    margin: 1rem 0;
  }
  .prose-custom td {
    border: 1px solid var(--color-hairline-strong, #ccc);
    padding: 8px;
    min-width: 60px;
    vertical-align: top;
  }

</style>

<script>
  function esc(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" }); }
    catch { return iso; }
  }

  function sanitize(html) {
    return html
      .replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, "")
      .replace(/\s+on\w+\s*=\s*(?:"[^"]*"|'[^']*'|[^\s>]+)/gi, "")
      .replace(/href\s*=\s*["']javascript:/gi, 'href="#"');
  }

  function renderContent(content) {
    return sanitize(content);
  }

  function isPostAccessible(p) {
    if (p.status === "published") return true;
    if (p.status === "scheduled" && p.scheduledAt) {
      return new Date(p.scheduledAt) <= new Date();
    }
    return false;
  }

  async function renderPost(slug) {
    const container = document.getElementById("post-content");
    if (!container) return;
    try {
      const res = await fetch(`/api/blog?slug=${encodeURIComponent(slug)}`);
      if (!res.ok) throw new Error("Not found");
      const post = await res.json();
      if (!isPostAccessible(post)) throw new Error("Not found");
      document.title = `${esc(post.title)} — Global Wealth Portfolio Blog`;
      container.innerHTML = `
        <p class="text-caption-mono text-gold mb-xs">Blog</p>
        <h1 class="text-display-lg mb-md">${esc(post.title)}</h1>
        <p class="text-caption text-mute mb-lg">${formatDate(post.publishedAt ?? post.updatedAt)}${post.authorName ? ` · By ${esc(post.authorName)}` : ""}</p>
        <div class="prose-custom text-body-md text-body leading-relaxed space-y-md">${renderContent(post.content)}</div>
      `;
    } catch {
      container.innerHTML = `
        <p class="text-caption-mono text-gold mb-xs">Blog</p>
        <h1 class="text-display-lg mb-md">Post not found</h1>
        <p class="text-body-md text-body">The blog post you're looking for could not be found.</p>
        <a href="/blog" class="inline-flex items-center gap-xs text-body-sm text-link hover:underline mt-lg">&larr; Back to blog</a>
      `;
    }
  }

  const params = new URLSearchParams(window.location.search);
  const slug = params.get("slug");
  if (slug) renderPost(slug);
</script>

---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Admin — Global Wealth Portfolio"
  description="Admin panel for blog management"
>
  <section class="container-page page-section pt-3xl pb-2xl">
    <div id="admin-app">
      <!-- Password gate -->
      <div id="login-screen" class="max-w-sm mx-auto text-center" style="display: none;">
        <p class="text-caption-mono text-gold mb-xs">Admin</p>
        <h1 class="text-display-md mb-lg">Blog Management</h1>
        <div class="card p-lg">
          <label class="label mb-sm" for="admin-password">Enter password</label>
          <input
            id="admin-password"
            type="password"
            class="input mb-md"
            placeholder="Password"
            autocomplete="off"
          />
          <button id="admin-login-btn" class="btn-primary w-full" type="button">Unlock</button>
          <p id="login-error" class="text-body-sm text-loss mt-sm" style="display: none;">Incorrect password</p>
          <button id="forgot-link" class="text-body-sm text-link hover:underline mt-sm" type="button" style="background: none; border: none; cursor: pointer;">Forgot password?</button>
        </div>
      </div>

      <!-- Forgot password screen -->
      <div id="forgot-screen" class="max-w-sm mx-auto text-center" style="display: none;">
        <p class="text-caption-mono text-gold mb-xs">Admin</p>
        <h1 class="text-display-md mb-lg">Reset Password</h1>
        <div class="card p-lg">
          <label class="label mb-sm" for="forgot-email">Email</label>
          <input
            id="forgot-email"
            type="email"
            class="input mb-md"
            readonly
          />
          <button id="send-otp-btn" class="btn-primary w-full mb-md" type="button">Send OTP</button>
          <div id="otp-group" style="display: none;">
            <label class="label mb-sm" for="otp-input">Enter OTP</label>
            <input
              id="otp-input"
              type="text"
              class="input mb-md"
              placeholder="6-digit OTP"
              maxlength="6"
              autocomplete="off"
            />
            <button id="verify-otp-btn" class="btn-primary w-full" type="button">Verify OTP</button>
          </div>
          <p id="forgot-status" class="text-body-sm mt-sm"></p>
          <button id="back-to-login" class="text-body-sm text-link hover:underline mt-sm" type="button" style="background: none; border: none; cursor: pointer;">&larr; Back to login</button>
        </div>
      </div>

      <!-- Reset password dialog -->
      <dialog id="reset-password-modal" class="rounded-lg p-0 max-w-sm w-full shadow-level-5 backdrop:bg-black/30">
        <div class="p-lg">
          <h2 class="text-display-sm mb-lg">Set new password</h2>
          <label class="label mb-sm" for="new-password">New password</label>
          <input
            id="new-password"
            type="password"
            class="input mb-md"
            placeholder="Min. 6 characters"
            autocomplete="off"
          />
          <label class="label mb-sm" for="confirm-password">Confirm password</label>
          <input
            id="confirm-password"
            type="password"
            class="input mb-md"
            placeholder="Repeat password"
            autocomplete="off"
          />
          <p id="reset-password-error" class="text-body-sm text-loss mb-sm" style="display: none;"></p>
          <div class="flex gap-sm justify-end">
            <button id="cancel-reset-btn" class="btn-secondary" type="button">Cancel</button>
            <button id="save-password-btn" class="btn-primary" type="button">Save</button>
          </div>
        </div>
      </dialog>

      <!-- Admin panel -->
      <div id="admin-panel" style="display: none;">
        <div class="flex items-center justify-between mb-lg">
          <div>
            <p class="text-caption-mono text-gold mb-xs">Admin</p>
            <h1 class="text-display-md">Blog Management</h1>
          </div>
          <button id="admin-logout-btn" class="btn-secondary" type="button">Lock</button>
        </div>

        <div class="flex items-center justify-between mb-lg">
          <p class="text-body-md text-body">Manage your blog posts</p>
          <button id="add-blog" class="btn-primary" type="button">+ New post</button>
        </div>

        <div id="admin-blog-list" class="grid grid-cols-1 gap-md mb-2xl">
          <div class="text-center py-5xl card-soft">
            <p class="text-body-md text-body">Loading…</p>
          </div>
        </div>

        <hr class="border-hairline my-4xl" />

        <!-- Server Sync -->
        <div class="mb-md">
          <p class="text-caption-mono text-gold mb-xs">Server Sync</p>
          <h2 class="text-display-md">Sync posts to server.</h2>
        </div>
        <div class="card p-lg space-y-md max-w-lg">
          <div>
            <label class="label" for="api-token">Admin Token</label>
            <input id="api-token" type="password" class="input" placeholder="Your secret admin token" />
            <p class="text-caption text-mute mt-xs">Token used to authenticate with the server API.</p>
          </div>
          <div class="flex items-center gap-sm flex-wrap">
            <button id="resync-btn" class="btn-primary" type="button">Resync Posts</button>
            <button id="fetch-posts-btn" class="btn-secondary" type="button">Fetch Posts</button>
            <span id="api-sync-status" class="text-caption text-mute"></span>
          </div>
        </div>

        <div class="text-center">
          <a href="/blog" class="text-body-sm text-link hover:underline">&larr; Back to blog</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Editor modal -->
  <dialog
    id="blog-modal"
    class="rounded-lg p-0 w-full shadow-level-5 backdrop:bg-black/30"
  >
    <form id="blog-form" method="dialog">
      <div class="modal-scroll">
        <div class="flex items-center justify-between mb-md px-lg pt-lg">
          <h2 class="text-display-sm" id="blog-modal-title">Write a new post</h2>
          <button type="button" data-close-modal class="btn-icon" aria-label="Close">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <input type="hidden" id="blog-id" name="id" />
        <div class="px-lg space-y-md">
          <div>
            <label class="label" for="blog-title">Title *</label>
            <input
              class="input"
              type="text"
              id="blog-title"
              name="title"
              required
              placeholder="e.g. Why I'm moving 20% into international equities"
            />
          </div>
          <div>
            <label class="label" for="blog-excerpt">Excerpt</label>
            <input
              class="input"
              type="text"
              id="blog-excerpt"
              name="excerpt"
              placeholder="A short summary shown on the list view"
            />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
            <div>
              <label class="label" for="blog-author">Author</label>
              <input class="input" type="text" id="blog-author" name="authorName" placeholder="Your name" />
            </div>
            <div>
              <label class="label" for="blog-tags">Tags <span class="text-mute font-normal">(comma separated)</span></label>
              <input class="input" type="text" id="blog-tags" name="tags" placeholder="investing, sip, review" />
            </div>
          </div>
        </div>
        <div class="editor-wrapper">
          <div class="editor-toolbar" id="editor-toolbar">
            <button type="button" data-fmt="bold" title="Bold"><strong>B</strong></button>
            <button type="button" data-fmt="italic" title="Italic"><em>I</em></button>
            <button type="button" data-fmt="underline" title="Underline"><u>U</u></button>
            <span class="toolbar-divider"></span>
            <button type="button" data-fmt="blockquote" title="Blockquote">&ldquo;</button>
            <button type="button" data-fmt="ul" title="Bullet list">UL</button>
            <button type="button" data-fmt="ol" title="Numbered list">OL</button>
            <span class="toolbar-divider"></span>
            <button type="button" data-fmt="link" id="link-btn" title="Insert link">Link</button>
            <button type="button" data-fmt="table" id="table-btn" title="Insert table">Table</button>
            <span class="toolbar-divider"></span>
            <button type="button" data-fmt="font-sans" title="Sans-serif">Sans</button>
            <button type="button" data-fmt="font-serif" title="Serif">Serif</button>
            <button type="button" data-fmt="font-mono" title="Monospace">Mono</button>
            <button type="button" data-fmt="font-arial" title="Arial">Arial</button>
            <span class="toolbar-divider"></span>
            <button type="button" data-fmt="size-down" title="Decrease font size">A-</button>
            <button type="button" data-fmt="size-up" title="Increase font size">A+</button>
            <span class="toolbar-divider"></span>
            <span class="toolbar-color-group" title="Text color">
              <button type="button" data-fmt="color-#0f1b2d" class="color-btn" style="background:#0f1b2d" title="Default"></button>
              <button type="button" data-fmt="color-#ff0000" class="color-btn" style="background:#ff0000" title="Red"></button>
              <button type="button" data-fmt="color-#0b5fff" class="color-btn" style="background:#0b5fff" title="Blue"></button>
              <button type="button" data-fmt="color-#008000" class="color-btn" style="background:#008000" title="Green"></button>
              <button type="button" data-fmt="color-#ff6600" class="color-btn" style="background:#ff6600" title="Orange"></button>
              <button type="button" data-fmt="color-#800080" class="color-btn" style="background:#800080" title="Purple"></button>
            </span>
          </div>
          <div
            class="input editor-content"
            id="blog-content"
            contenteditable="true"
            role="textbox"
            aria-multiline="true"
            data-placeholder="Write your thoughts here..."
            style="min-height: 450px; padding: 12px; line-height: 1.55;"
          ></div>
          <!-- Link dialog -->
          <dialog id="link-dialog" class="rounded-lg p-0 shadow-level-5 backdrop:bg-black/30 border-0 max-w-sm w-full">
            <div class="p-md">
              <h3 class="text-display-xs mb-md">Insert Link</h3>
              <div class="space-y-sm">
                <div>
                  <label class="label text-body-xs" for="link-url">URL</label>
                  <input id="link-url" type="url" class="input" placeholder="https://" autocomplete="off" />
                </div>
                <div>
                  <label class="label text-body-xs" for="link-text">Text to display <span class="text-mute font-normal">(optional)</span></label>
                  <input id="link-text" type="text" class="input" placeholder="Selected text or custom label" autocomplete="off" />
                </div>
              </div>
              <div class="flex justify-end gap-sm mt-md">
                <button id="link-cancel" type="button" class="btn-secondary">Cancel</button>
                <button id="link-insert" type="button" class="btn-primary">Insert</button>
              </div>
            </div>
          </dialog>
          <!-- Table dialog -->
          <dialog id="table-dialog" class="rounded-lg p-0 shadow-level-5 backdrop:bg-black/30 border-0 max-w-sm w-full">
            <div class="p-md">
              <h3 class="text-display-xs mb-md">Insert Table</h3>
              <div class="flex gap-md items-end">
                <div class="flex-1">
                  <label class="label text-body-xs" for="table-rows">Rows</label>
                  <input id="table-rows" type="number" class="input" value="3" min="1" max="20" />
                </div>
                <div class="flex-1">
                  <label class="label text-body-xs" for="table-cols">Columns</label>
                  <input id="table-cols" type="number" class="input" value="3" min="1" max="20" />
                </div>
              </div>
              <div class="flex justify-end gap-sm mt-md">
                <button id="table-cancel" type="button" class="btn-secondary">Cancel</button>
                <button id="table-insert" type="button" class="btn-primary">Insert</button>
              </div>
            </div>
          </dialog>
        </div>
        <div class="px-lg pb-lg space-y-md mt-md">
          <div>
            <label class="label">Status</label>
            <div class="flex gap-sm">
              <label class="flex items-center gap-xs cursor-pointer">
                <input type="radio" name="status" value="draft" class="blog-status-radio accent-current" />
                <span class="text-body-sm">Draft</span>
              </label>
              <label class="flex items-center gap-xs cursor-pointer">
                <input type="radio" name="status" value="published" class="blog-status-radio accent-current" checked />
                <span class="text-body-sm">Published</span>
              </label>
              <label class="flex items-center gap-xs cursor-pointer">
                <input type="radio" name="status" value="scheduled" class="blog-status-radio accent-current" />
                <span class="text-body-sm">Scheduled</span>
              </label>
            </div>
            <div id="scheduled-at-group" class="mt-sm" style="display:none;">
              <label class="label" for="blog-scheduled-at">Schedule publish date & time</label>
              <input class="input" type="datetime-local" id="blog-scheduled-at" name="scheduledAt" />
              <p class="text-caption text-mute mt-xs">The post will be published automatically after this time.</p>
            </div>
          </div>
          <div class="flex justify-between items-center">
            <p class="text-caption text-mute">Posts are stored locally in your browser.</p>
            <div class="flex gap-sm">
              <button type="button" data-close-modal class="btn-secondary">Cancel</button>
              <button type="submit" class="btn-primary">Save post</button>
            </div>
          </div>
        </div>
      </div>
    </form>
  </dialog>
</Layout>

<style>
  #blog-modal {
    width: min(95vw, 960px);
  }
  #blog-form {
    max-height: 90vh;
    overflow-y: auto;
  }
  #blog-form .modal-scroll {
    display: flex;
    flex-direction: column;
  }
  .editor-wrapper {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 300px;
  }
  .editor-toolbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 6px 8px;
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
  }
  .editor-toolbar button {
    background: none;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 3px 8px;
    font-size: 0.8125rem;
    cursor: pointer;
    color: var(--color-body);
    font-family: var(--font-sans);
    line-height: 1.4;
    min-width: 28px;
    text-align: center;
    transition: background 100ms ease;
  }
  .editor-toolbar button:hover {
    background: var(--color-hairline);
  }
  .editor-toolbar button:active {
    background: var(--color-hairline-strong);
  }
  .toolbar-divider {
    display: inline-block;
    width: 1px;
    background: var(--color-hairline);
    margin: 4px 5px;
  }
  .toolbar-color-group {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 2px 4px;
    border: 1px solid var(--color-hairline);
    border-radius: 4px;
    background: var(--color-canvas);
  }
  .color-btn {
    width: 16px;
    height: 16px;
    padding: 0;
    border: 1px solid var(--color-hairline-strong);
    border-radius: 2px;
    cursor: pointer;
    display: block;
    flex-shrink: 0;
  }
  .color-btn:hover {
    border-color: var(--color-ink);
    transform: scale(1.15);
  }
  .editor-content {
    border-top-left-radius: 0 !important;
    border-top-right-radius: 0 !important;
    outline: none;
    min-height: 450px;
    height: auto;
    overflow-wrap: break-word;
    word-break: break-word;
    overflow-y: auto;
    flex: 1;
  }
  .editor-content:empty:before {
    content: attr(data-placeholder);
    color: var(--color-mute);
    pointer-events: none;
  }
  .editor-content table {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
    margin: 0.5rem 0;
  }
  .editor-content td {
    border: 1px solid var(--color-hairline-strong, #ccc);
    padding: 8px;
    min-width: 60px;
    vertical-align: top;
  }
  .editor-content font[size="1"] { font-size: 0.75rem; }
  .editor-content font[size="2"] { font-size: 0.875rem; }
  .editor-content font[size="3"] { font-size: 1rem; }
  .editor-content font[size="4"] { font-size: 1.25rem; }
  .editor-content font[size="5"] { font-size: 1.5rem; }
  .editor-content font[size="6"] { font-size: 2rem; }
  .editor-content font[size="7"] { font-size: 2.5rem; }
  .editor-content font[face="sans-serif"] { font-family: sans-serif; }
  .editor-content font[face="serif"] { font-family: serif; }
  .editor-content font[face="monospace"] { font-family: monospace; }
</style>

<script>
  import "../scripts/admin.ts";
</script>

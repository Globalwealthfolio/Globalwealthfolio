---
import Layout from "../layouts/Layout.astro";
import { fetchLiveBenchmarks } from "../lib/benchmarks-api";
const initialServerData = await fetchLiveBenchmarks();
---

<Layout title="Benchmarks — Global Wealth Portfolio">
  <section class="container-page page-section pt-3xl pb-2xl">
    <div class="mb-2xl max-w-3xl">
      <p class="text-caption-mono text-gold mb-xs">Benchmarks</p>
      <h1 class="text-display-lg">Compare your portfolio to the market.</h1>
      <p class="text-body-md text-body mt-sm leading-relaxed">
        Reference returns for major indices across India, the US, global
        equities, gold, and crypto. Data is fetched live from Yahoo Finance
        every few hours; if the network is unavailable we fall back to a
        cached snapshot, and finally to representative long-term figures.
      </p>
    </div>

    <!-- Server-side data for immediate use (fetched at build time) -->
    <script define:vars={{ initialServerData }} is:inline>
      window.__BENCHMARK_INITIAL_DATA__ = initialServerData;
    </script>

    <!-- Your portfolio vs benchmarks -->
    <div class="card-elevated mb-2xl">
      <div class="flex items-center justify-between mb-md gap-sm flex-wrap">
        <div class="flex items-center gap-sm">
          <h2 class="text-display-sm">Your portfolio vs benchmarks</h2>
          <span class="badge badge-gain hidden" data-source-badge>● Live</span>
        </div>
        <div class="flex items-center gap-sm">
          <p class="text-caption text-mute">Updated <span data-fetched-at>—</span></p>
          <button id="refresh-benchmarks" class="btn-secondary" style="height: 28px; padding: 0 10px; font-size: 12px;" type="button">
            <svg class="w-3 h-3 inline-block mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12a9 9 0 1 1-3-6.7L21 8"></path>
              <path d="M21 3v5h-5"></path>
            </svg>
            Refresh
          </button>
        </div>
      </div>
      <div class="card-soft p-0 overflow-hidden">
        <table class="w-full text-body-sm" data-table="benchmarks">
          <thead>
            <tr class="text-left text-caption-mono text-body bg-canvas-soft-2">
              <th class="font-medium py-sm px-md">Series</th>
              <th class="font-medium py-sm px-md text-right">1M</th>
              <th class="font-medium py-sm px-md text-right">6M</th>
              <th class="font-medium py-sm px-md text-right">1Y</th>
              <th class="font-medium py-sm px-md text-right hide-tablet">3Y CAGR</th>
              <th class="font-medium py-sm px-md text-right hide-tablet">5Y CAGR</th>
            </tr>
          </thead>
          <tbody id="bench-tbody">
            <tr>
              <td colspan="6" class="text-center py-5xl text-body">Loading live data…</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-caption text-mute mt-md">
        Live data is sourced from Yahoo Finance via a CORS-friendly proxy. The Crisil Debt Index uses long-term reference values because a free live feed is not publicly available.
      </p>
    </div>

    <!-- Performance vs benchmarks chart -->
    <div class="card-elevated">
      <h2 class="text-display-sm mb-md">Performance comparison</h2>
      <div class="h-56 max-sm:chart-sm">
        <canvas id="benchChart"></canvas>
      </div>
    </div>
  </section>
</Layout>

<script>
  import "../scripts/benchmarks.ts";
</script>

---
import { currencies } from "../lib/currency";
const path = Astro.url.pathname;

const currencyList = Object.entries(currencies).map(([code, meta]) => ({
  code,
  symbol: meta.symbol,
  name: meta.name,
}));

const navLinks = [
  { href: "/dashboard", label: "Dashboard" },
  { href: "/investments", label: "Investments" },
  { href: "/expenses", label: "Expenses" },
  { href: "/goals", label: "Goals" },
  { href: "/benchmarks", label: "Benchmarks" },
  { href: "/emi", label: "EMI" },
  { href: "/blog", label: "Blog" },
  { href: "/import", label: "Import" },
];

const isActive = (href: string) => {
  if (href === "/" && path === "/") return true;
  if (href !== "/" && path.startsWith(href)) return true;
  return false;
};
---

<header
  class="sticky top-0 z-40 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline"
  style="height: 64px"
>
  <div class="container-page h-full flex items-center justify-between gap-md">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0 group" aria-label="Global Wealth Portfolio home">
      <span
        class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-ink text-gold font-bold text-sm relative overflow-hidden"
        aria-hidden="true"
      >
        <span class="relative z-10">G</span>
        <span class="absolute inset-0 bg-gradient-to-br from-transparent via-white/10 to-transparent opacity-50"></span>
      </span>
      <span class="text-body-sm-strong text-ink hidden sm:inline tracking-tight">
        Global <span class="text-gradient-gold font-semibold">Wealth</span> Portfolio
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "btn-ghost",
              isActive(link.href) && "bg-canvas-soft-2 text-ink",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-1.5">
      <button
        type="button"
        class="btn-icon"
        data-theme-toggle
        aria-label="Toggle color theme"
        title="Toggle theme"
      >
        <svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <div class="relative hidden sm:block" data-lang-menu>
        <button type="button" class="btn-icon" data-lang-toggle aria-label="Change language" aria-haspopup="menu">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"></path>
          </svg>
        </button>
        <div
          data-lang-dropdown
          class="hidden absolute right-0 top-full mt-2 min-w-44 bg-canvas rounded-md shadow-level-4 p-1 z-50"
          role="menu"
        >
          {
            [
              { code: "en", label: "English" },
              { code: "hi", label: "हिन्दी" },
              { code: "es", label: "Español" },
              { code: "fr", label: "Français" },
              { code: "de", label: "Deutsch" },
              { code: "ja", label: "日本語" },
              { code: "zh", label: "中文" },
              { code: "pt", label: "Português" },
              { code: "ru", label: "Русский" },
              { code: "ar", label: "العربية" },
            ].map((lang) => (
              <button
                type="button"
                class="w-full text-left px-3 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
                data-set-lang={lang.code}
                role="menuitem"
              >
                {lang.label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="relative hidden sm:block" data-currency-menu>
        <button type="button" class="btn-icon" data-currency-toggle aria-label="Change currency" aria-haspopup="menu">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="1" x2="12" y2="23"></line>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
          </svg>
        </button>
        <div
          data-currency-dropdown
          class="hidden absolute right-0 top-full mt-2 min-w-48 bg-canvas rounded-md shadow-level-4 p-1 z-50 max-h-80 overflow-y-auto scroll-thin"
          role="menu"
        >
          {
            currencyList.map((c) => (
              <button
                type="button"
                class="w-full text-left px-3 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
                data-set-currency={c.code}
                role="menuitem"
              >
                <span class="mr-1.5 text-mute">{c.symbol}</span>
                {c.name}
              </button>
            ))
          }
        </div>
      </div>

      <a href="/settings" class="btn-icon hidden sm:inline-flex" aria-label="Settings">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
      </a>

      <a href="/dashboard" class="btn-primary hidden md:inline-flex" style="height: 32px; padding: 0 12px; font-size: 13px;">
        Open Dashboard
      </a>

      <button
        type="button"
        class="btn-icon lg:hidden"
        data-mobile-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-hairline bg-canvas"
    data-mobile-menu
  >
    <nav class="container-page py-3 flex flex-col gap-0.5" aria-label="Mobile primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "px-3 py-2 rounded-sm text-body-sm hover:bg-canvas-soft-2 text-body hover:text-ink",
              isActive(link.href) && "bg-canvas-soft-2 text-ink font-medium",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/settings"
        class:list={[
          "px-3 py-2 rounded-sm text-body-sm hover:bg-canvas-soft-2 text-body hover:text-ink",
        ]}
      >
        Settings
      </a>
    </nav>
  </div>
</header>

<script>
  // Theme toggle
  document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
    window.gwp?.toggleTheme();
  });

  // Language menu
  const langMenu = document.querySelector("[data-lang-menu]");
  const langToggle = document.querySelector("[data-lang-toggle]");
  const langDropdown = document.querySelector("[data-lang-dropdown]");

  // Currency menu
  const currencyMenu = document.querySelector("[data-currency-menu]");
  const currencyToggle = document.querySelector("[data-currency-toggle]");
  const currencyDropdown = document.querySelector("[data-currency-dropdown]");

  langToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    currencyDropdown?.classList.add("hidden");
    langDropdown?.classList.toggle("hidden");
  });
  document.querySelectorAll<HTMLButtonElement>("[data-set-lang]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const code = btn.dataset.setLang!;
      window.gwp?.setLanguage(code as never);
      langDropdown?.classList.add("hidden");
      currencyDropdown?.classList.add("hidden");
      // Re-render i18n strings
      window.dispatchEvent(new CustomEvent("gwp:lang", { detail: code }));
    });
  });

  currencyToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    langDropdown?.classList.add("hidden");
    currencyDropdown?.classList.toggle("hidden");
  });
  document.addEventListener("click", (e) => {
    if (!langMenu?.contains(e.target as Node)) {
      langDropdown?.classList.add("hidden");
    }
    if (!currencyMenu?.contains(e.target as Node)) {
      currencyDropdown?.classList.add("hidden");
    }
  });
  document.querySelectorAll<HTMLButtonElement>("[data-set-currency]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const code = btn.dataset.setCurrency!;
      window.gwp?.setCurrency(code as never);
      currencyDropdown?.classList.add("hidden");
    });
  });

  // Mobile menu
  const mobileToggle = document.querySelector("[data-mobile-toggle]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  mobileToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    mobileToggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // "New" badge on Blog nav link
  (async () => {
    try {
      const res = await fetch("/api/blog");
      const data = await res.json();
      const posts = data.posts || [];
      const msPerWeek = 7 * 24 * 60 * 60 * 1000;
      const hasNew = posts.some((p) => {
        const d = new Date(p.publishedAt ?? p.updatedAt);
        return Date.now() - d < msPerWeek;
      });
      if (hasNew) {
        document.querySelectorAll('a[href="/blog"]').forEach((el) => {
          const sup = document.createElement("sup");
          sup.textContent = "New";
          sup.style.cssText = "font-size:0.6em;color:#10b981;margin-left:3px;position:relative;top:-0.5em;font-weight:500;";
          el.appendChild(sup);
        });
      }
    } catch {}
  })();
</script>

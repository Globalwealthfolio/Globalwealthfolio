---
import { currencies } from "../lib/currency";
const path = Astro.url.pathname;

const currencyList = Object.entries(currencies).map(([code, meta]) => ({
  code,
  symbol: meta.symbol,
  name: meta.name,
}));

const langs = [
  { code: "en", label: "English" },
  { code: "hi", label: "हिन्दी" },
  { code: "es", label: "Español" },
  { code: "fr", label: "Français" },
  { code: "de", label: "Deutsch" },
  { code: "ja", label: "日本語" },
  { code: "zh", label: "中文" },
  { code: "pt", label: "Português" },
  { code: "ru", label: "Русский" },
  { code: "ar", label: "العربية" },
];

const primaryLinks = [
  { href: "/dashboard", label: "Dashboard" },
  { href: "/investments", label: "Investments" },
  { href: "/expenses", label: "Expenses" },
  { href: "/goals", label: "Goals" },
  { href: "/calculators", label: "Calculators" },
  { href: "/blog", label: "Blog" },
];

const secondaryLinks = [
  { href: "/benchmarks", label: "Benchmarks" },
  { href: "/emi", label: "EMI" },
  { href: "/import", label: "Import" },
];

const allLinks = [...primaryLinks, ...secondaryLinks];

const isActive = (href: string) => {
  if (href === "/" && path === "/") return true;
  if (href !== "/" && path.startsWith(href)) return true;
  return false;
};
---

<header
  class="sticky top-0 z-40 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline"
  style="height: 64px"
>
  <div class="container-page h-full flex items-center justify-between gap-md">
    <!-- Logo + tagline -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Global Wealth Portfolio home">
      <span
        class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-ink text-gold font-bold text-sm relative overflow-hidden shrink-0"
        aria-hidden="true"
      >
        <span class="relative z-10">G</span>
        <span class="absolute inset-0 bg-gradient-to-br from-transparent via-white/10 to-transparent opacity-50"></span>
      </span>
      <div class="flex flex-col leading-tight">
        <span class="text-body-sm-strong text-ink hidden sm:inline tracking-tight leading-tight">
          Global <span class="text-gradient-gold font-semibold">Wealth</span> Portfolio
        </span>
        <span class="text-[11px] text-mute hidden xl:inline leading-tight -mt-0.5">
          Track. Invest. Grow.
        </span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        primaryLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "btn-ghost",
              isActive(link.href) && "bg-canvas-soft-2 text-ink",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <!-- More dropdown for secondary links (hover to open) -->
      <div class="relative group" data-nav-more>
        <button
          type="button"
          class:list={[
            "btn-ghost",
            secondaryLinks.some((l) => isActive(l.href)) && "bg-canvas-soft-2 text-ink",
          ]}
          aria-haspopup="menu"
        >
          More
          <svg class="w-3.5 h-3.5 ml-0.5 transition-transform duration-150 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div
          data-nav-more-dropdown
          class="invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 absolute left-0 top-full mt-1 min-w-40 bg-canvas rounded-md shadow-level-4 p-1 z-50"
          role="menu"
        >
          {
            secondaryLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "block px-3 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors",
                  isActive(link.href) && "bg-canvas-soft-2 text-ink font-medium",
                ]}
                role="menuitem"
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-1.5">
      <!-- Theme toggle -->
      <button
        type="button"
        class="btn-icon"
        data-theme-toggle
        aria-label="Toggle color theme"
        title="Toggle theme"
      >
        <svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- Settings dropdown (language, currency, backup) -->
      <div class="relative hidden sm:block" data-settings-menu>
        <button
          type="button"
          class="btn-icon"
          data-settings-toggle
          aria-label="Settings"
          aria-haspopup="menu"
          aria-expanded="false"
          title="Settings"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </svg>
        </button>
        <div
          data-settings-dropdown
          class="hidden absolute right-0 top-full mt-2 min-w-52 bg-canvas rounded-md shadow-level-4 p-2 z-50"
          role="menu"
        >
          <!-- Language -->
          <div class="text-caption-mono text-mute px-1 mb-1" aria-hidden="true">Language</div>
          <div class="grid grid-cols-2 gap-0.5 mb-2">
            {
              langs.map((lang) => (
                <button
                  type="button"
                  class="text-left px-2 py-1 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors truncate"
                  data-set-lang={lang.code}
                  role="menuitem"
                >
                  {lang.label}
                </button>
              ))
            }
          </div>
          <div class="hairline my-1" role="separator"></div>

          <!-- Currency -->
          <div class="text-caption-mono text-mute px-1 mb-1 mt-2" aria-hidden="true">Currency</div>
          <div class="max-h-48 overflow-y-auto scroll-thin -mx-1 px-1">
            <div class="grid grid-cols-2 gap-0.5">
              {
                currencyList.map((c) => (
                  <button
                    type="button"
                    class="text-left px-2 py-1 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors truncate"
                    data-set-currency={c.code}
                    role="menuitem"
                  >
                    <span class="mr-1 text-mute">{c.symbol}</span>
                    {c.code}
                  </button>
                ))
              }
            </div>
          </div>
          <div class="hairline my-1" role="separator"></div>

          <!-- Actions -->
          <button
            type="button"
            class="w-full flex items-center gap-2 px-2 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
            data-save-backup
            role="menuitem"
          >
            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
              <polyline points="17 21 17 13 7 13 7 21"></polyline>
              <polyline points="7 3 7 8 15 8"></polyline>
            </svg>
            Save Backup
          </button>
          <button
            type="button"
            class="w-full flex items-center gap-2 px-2 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
            data-open-backup
            role="menuitem"
          >
            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            Open Backup
          </button>

          <div class="hairline my-1" role="separator"></div>

          <a
            href="/settings"
            class="flex items-center gap-2 px-2 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
            role="menuitem"
          >
            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            All Settings
          </a>
        </div>
      </div>

      <!-- Primary CTA -->
      <a href="/dashboard" class="btn-primary hidden md:inline-flex" style="height: 32px; padding: 0 14px; font-size: 13px;">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Start Tracking
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="btn-icon lg:hidden"
        data-mobile-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-hairline bg-canvas shadow-level-4"
    data-mobile-menu
  >
    <div class="container-page py-4 flex flex-col gap-3">
      <!-- Mobile CTA -->
      <a href="/dashboard" class="btn-primary w-full justify-center">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Start Tracking
      </a>

      <!-- Mobile nav links -->
      <nav class="flex flex-col gap-0.5" aria-label="Mobile primary">
        {
          allLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "px-3 py-2 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors",
                isActive(link.href) && "bg-canvas-soft-2 text-ink font-medium",
              ]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="hairline" role="separator"></div>

      <!-- Mobile utilities -->
      <div class="flex flex-col gap-2">
        <!-- Language -->
        <div class="text-caption-mono text-mute px-1">Language</div>
        <div class="grid grid-cols-2 gap-1">
          {
            langs.map((lang) => (
              <button
                type="button"
                class="text-left px-2.5 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors truncate"
                data-set-lang={lang.code}
              >
                {lang.label}
              </button>
            ))
          }
        </div>

        <div class="hairline my-0.5" role="separator"></div>

        <!-- Currency -->
        <div class="text-caption-mono text-mute px-1">Currency</div>
        <div class="grid grid-cols-2 gap-1 max-h-48 overflow-y-auto scroll-thin">
          {
            currencyList.map((c) => (
              <button
                type="button"
                class="text-left px-2.5 py-1.5 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors truncate"
                data-set-currency={c.code}
              >
                <span class="mr-1 text-mute">{c.symbol}</span>
                {c.code} — {c.name}
              </button>
            ))
          }
        </div>

        <div class="hairline my-0.5" role="separator"></div>

        <!-- Mobile actions -->
        <button
          type="button"
          class="flex items-center gap-2 px-2.5 py-2 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
          data-save-backup
        >
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
            <polyline points="17 21 17 13 7 13 7 21"></polyline>
            <polyline points="7 3 7 8 15 8"></polyline>
          </svg>
          Save Backup
        </button>
        <button
          type="button"
          class="flex items-center gap-2 px-2.5 py-2 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
          data-open-backup
        >
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
          </svg>
          Open Backup
        </button>
        <a
          href="/settings"
          class="flex items-center gap-2 px-2.5 py-2 rounded-sm text-body-sm text-body hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </svg>
          All Settings
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Save backup
  document.querySelectorAll("[data-save-backup]").forEach((el) => {
    el.addEventListener("click", () => window.gwp?.exportData());
  });

  // Open backup
  document.querySelectorAll("[data-open-backup]").forEach((el) => {
    el.addEventListener("click", () => window.gwp?.importData());
  });

  // Theme toggle
  document.querySelector("[data-theme-toggle]")?.addEventListener("click", () => {
    window.gwp?.toggleTheme();
  });

  // --- Settings dropdown ---
  const settingsMenu = document.querySelector("[data-settings-menu]");
  const settingsToggle = document.querySelector("[data-settings-toggle]");
  const settingsDropdown = document.querySelector("[data-settings-dropdown]");

  settingsToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    settingsDropdown?.classList.toggle("hidden");
    const isExpanded = !settingsDropdown?.classList.contains("hidden");
    settingsToggle.setAttribute("aria-expanded", String(isExpanded));
  });

  // --- Language setter ---
  document.querySelectorAll<HTMLButtonElement>("[data-set-lang]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const code = btn.dataset.setLang!;
      window.gwp?.setLanguage(code as never);
      settingsDropdown?.classList.add("hidden");
      window.dispatchEvent(new CustomEvent("gwp:lang", { detail: code }));
    });
  });

  // --- Currency setter ---
  document.querySelectorAll<HTMLButtonElement>("[data-set-currency]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const code = btn.dataset.setCurrency!;
      window.gwp?.setCurrency(code as never);
      settingsDropdown?.classList.add("hidden");
    });
  });

  // --- Close dropdowns on outside click ---
  document.addEventListener("click", (e) => {
    if (!settingsMenu?.contains(e.target as Node)) {
      settingsDropdown?.classList.add("hidden");
      settingsToggle?.setAttribute("aria-expanded", "false");
    }
  });

  // --- Mobile menu ---
  const mobileToggle = document.querySelector("[data-mobile-toggle]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  mobileToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden");
    mobileToggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu on nav link click
  document.querySelectorAll("#mobile-menu a[href]").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      mobileToggle?.setAttribute("aria-expanded", "false");
    });
  });

  // "New" badge on Blog nav link
  (async () => {
    try {
      const res = await fetch("/api/blog");
      const data = await res.json();
      const posts = data.posts || [];
      const msPerWeek = 7 * 24 * 60 * 60 * 1000;
      const hasNew = posts.some((p) => {
        const d = new Date(p.publishedAt ?? p.updatedAt);
        return Date.now() - d < msPerWeek;
      });
      if (hasNew) {
        document.querySelectorAll('a[href="/blog"]').forEach((el) => {
          const sup = document.createElement("sup");
          sup.textContent = "New";
          sup.style.cssText = "font-size:0.6em;color:#10b981;margin-left:3px;position:relative;top:-0.5em;font-weight:500;";
          el.appendChild(sup);
        });
      }
    } catch {}
  })();
</script>
